# Configuration Nginx pour Samabutik sur Hostinger VPS
# Emplacement suggéré : /etc/nginx/sites-available/samabutik

server {
    listen 80;
    server_name samabutik.com www.samabutik.com;

    # Frontend (fichiers statiques générés par npm run build)
    root /root/samabutik/dist;
    index index.html;

    location / {
        try_files $uri $uri/ /index.html;
    }

    # API Proxy vers le serveur Node.js (PM2)
    location /api/ {
        proxy_pass http://127.0.0.1:3000;
        proxy_http_version 1.1;
        proxy_set_header Upgrade $http_upgrade;
        proxy_set_header Connection 'upgrade';
        proxy_set_header Host $host;
        proxy_cache_bypass $http_upgrade;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
    }

    # Servir les uploads localement
    location /uploads/ {
        alias /root/samabutik/uploads/;
        expires 30d;
        add_header Cache-Control "public, no-transform";
    }

    # Sécurité supplémentaire
    client_max_body_size 10M;
}
