# ============================================================
# SAMA BUTIK - CONFIGURATION D'ENVIRONNEMENT HOSTINGER
# ============================================================
# Copiez ce fichier sous le nom `.env` et remplissez les valeurs
# depuis le panel de contrôle Hostinger ou via SSH.

# 1. PORT: Le port d'écoute (Hostinger l'assigne souvent dynamiquement,
#          ou 3000 si vous utilisez un VPS classique)
PORT=3000

# 2. NODE_ENV: Environnement de déploiement (doit être 'production' sur Hostinger)
NODE_ENV=production

# 3. JWT_SECRET: Clé secrète robuste pour signer les tokens (ne jamais la divulguer)
JWT_SECRET=super_secret_key_pour_la_production

# 4. GEMINI_API_KEY: Clé API pour Gemini (optionnelle selon les features actives)
GEMINI_API_KEY=votre_cle_gemini

# 5. ADMIN_EMAIL & ADMIN_PASSWORD: Identifiants du tout premier administrateur
ADMIN_EMAIL=admin@samabutik.com
ADMIN_PASSWORD=mot_de_passe_admin_securise

# 6. EXTERNAL URL (Optionnel)
NEXT_PUBLIC_APP_URL=https://samabutik.com

# 7. SUPABASE (Si vous utilisez toujours l'authentification Supabase)
VITE_SUPABASE_URL=https://tepsspmrqgvkzxzfbrcx.supabase.co
VITE_SUPABASE_PUBLISHABLE_KEY=votre_cle_publique_supabase
VITE_SUPABASE_PROJECT_ID=tepsspmrqgvkzxzfbrcx

# 8. GOOGLE OAUTH
NEXT_PUBLIC_GOOGLE_CLIENT_ID=255010995813-xxxxxxxx.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=votre_secret_google

