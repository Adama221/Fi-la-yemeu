<IfModule mod_rewrite.c>
  RewriteEngine On
  RewriteBase /

  # Redirect all traffic to node if possible (depends on Hostinger setup)
  # But usually handles SPA routing here if node serves dist
  
  RewriteCond %{REQUEST_FILENAME} !-f
  RewriteCond %{REQUEST_FILENAME} !-d
  RewriteCond %{REQUEST_URI} !^/api/ [NC]
  RewriteRule . /index.html [L]
</IfModule>
